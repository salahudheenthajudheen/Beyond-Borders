---
interface Props {
  slug: string;
  name: string;
  usecaseCount: number;
  icon: string;
}
const { slug, name, usecaseCount, icon } = Astro.props;
---

<a href={`/verticals/${slug}/`} class="vertical-card">
  <span class="vertical-card__icon">{icon}</span>
  <h3 class="vertical-card__name">{name}</h3>
  <span class="vertical-card__count">
    {usecaseCount} use case{usecaseCount !== 1 ? 's' : ''}
  </span>
</a>

<style>
  .vertical-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    text-decoration: none;
    color: inherit;
    background: hsla(230, 20%, 20%, 0.6);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid hsla(230, 20%, 30%, 0.4);
    border-radius: 16px;
    padding: 2rem 1.5rem;
    aspect-ratio: 1 / 1;
    min-height: 180px;
    transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.3s ease;
    position: relative;
  }

  .vertical-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 40px hsla(270, 80%, 40%, 0.15);
    border-color: transparent;
  }

  /* Gradient border on hover using pseudo-element */
  .vertical-card::before {
    content: '';
    position: absolute;
    inset: -1px;
    border-radius: 17px;
    padding: 1px;
    background: linear-gradient(135deg, hsl(270, 80%, 65%), hsl(285, 75%, 55%), hsl(185, 85%, 55%));
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    opacity: 0;
    transition: opacity 0.3s ease;
    pointer-events: none;
  }

  .vertical-card:hover::before {
    opacity: 1;
  }

  .vertical-card__icon {
    font-size: 2.8rem;
    line-height: 1;
  }

  .vertical-card__name {
    font-family: 'Outfit', sans-serif;
    font-weight: 700;
    font-size: 1rem;
    color: hsl(0, 0%, 95%);
    margin: 0;
    text-align: center;
    line-height: 1.3;
  }

  .vertical-card__count {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.75rem;
    font-weight: 500;
    color: hsl(270, 80%, 75%);
    background: hsla(270, 80%, 65%, 0.12);
    padding: 0.2rem 0.6rem;
    border-radius: 20px;
    border: 1px solid hsla(270, 80%, 65%, 0.2);
  }
</style>
