---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import CompanyCard from '../../components/CompanyCard.astro';
import { getCompanies } from '../../utils/content-loader';

const companies = getCompanies();

const comingSoon = [
  { name: 'OpenAI', slug: 'openai' },
  { name: 'NVIDIA', slug: 'nvidia' },
  { name: 'DeepMind', slug: 'deepmind' },
  { name: 'SpaceX', slug: 'spacex' },
  { name: 'Tesla', slug: 'tesla' },
  { name: 'Beckn / ONDC', slug: 'beckn-ondc' },
];
---

<BaseLayout title="Companies" description="Explore frontier companies whose technologies power the next wave of innovation.">

  <!-- ═══ Hero ═══ -->
  <Hero
    title="Frontier Companies"
    subtitle="Handpicked companies building the future with AI, robotics, and deep technology — mapped to real-world opportunities."
  />

  <!-- ═══ Section Divider ═══ -->
  <div class="section-divider"></div>

  <!-- ═══ Active Companies ═══ -->
  <section class="section" id="active-companies">
    <div class="container">
      <h2 class="section-heading animate-fade-in-up">
        Active Companies
      </h2>
      <p class="section-subtitle animate-fade-in-up delay-1">
        Browse use cases, projects, and research for each company
      </p>

      <div class="companies-grid">
        {companies.map((company, i) => (
          <div class={`animate-fade-in-up delay-${Math.min(i + 1, 6)}`}>
            <CompanyCard
              slug={company.slug}
              name={company.name}
              summary={company.summary}
              usecaseCount={company.usecaseCount}
              projectCount={company.projectCount}
              verticals={company.verticals}
            />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ Section Divider ═══ -->
  <div class="section-divider"></div>

  <!-- ═══ Coming Soon ═══ -->
  <section class="section" id="coming-soon">
    <div class="container">
      <h2 class="section-heading animate-fade-in-up">
        Coming Soon
      </h2>
      <p class="section-subtitle animate-fade-in-up delay-1">
        These companies are next on our roadmap — want to help? Open a PR!
      </p>

      <div class="coming-grid">
        {comingSoon.map((company, i) => (
          <div class={`coming-card glass-card animate-fade-in-up delay-${Math.min(i + 1, 6)}`}>
            <div class="coming-card__badge">
              <span class="badge coming-badge">Coming Soon</span>
            </div>
            <h3 class="coming-card__name">{company.name}</h3>
            <p class="coming-card__hint">
              Help us map this company's technology to real-world use cases.
            </p>
            <a
              href="https://github.com/salahudheenthajudheen/Beyond-Borders/issues"
              class="coming-card__link"
              target="_blank"
              rel="noopener"
            >
              Contribute →
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* ── Section Heading Styles ── */
  .section-heading {
    font-family: 'Outfit', sans-serif;
    font-weight: 800;
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    text-align: center;
    margin-bottom: 0.75rem;
    color: var(--text-primary);
    line-height: 1.2;
  }

  .section-subtitle {
    font-family: 'Inter', sans-serif;
    font-size: clamp(0.95rem, 1.5vw, 1.15rem);
    color: hsl(230, 15%, 60%);
    text-align: center;
    max-width: 600px;
    margin: 0 auto 3rem;
    line-height: 1.6;
  }

  /* ── Section Divider ── */
  .section-divider {
    height: 1px;
    background: linear-gradient(90deg, transparent, hsla(270, 80%, 65%, 0.2), hsla(185, 85%, 55%, 0.15), transparent);
    max-width: 800px;
    margin: 0 auto;
  }

  /* ── Companies Grid ── */
  .companies-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: 1.5rem;
  }

  /* ── Coming Soon Grid ── */
  .coming-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.25rem;
  }

  .coming-card {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    opacity: 0.6;
    transition: opacity 0.3s ease, transform 0.25s ease, box-shadow 0.25s ease;
    padding: 2rem 1.5rem;
    position: relative;
    overflow: hidden;
  }

  .coming-card::after {
    content: '';
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      -45deg,
      transparent,
      transparent 8px,
      hsla(230, 20%, 25%, 0.15) 8px,
      hsla(230, 20%, 25%, 0.15) 16px
    );
    pointer-events: none;
    opacity: 0.3;
    border-radius: 16px;
  }

  .coming-card:hover {
    opacity: 0.85;
  }

  .coming-card__badge {
    position: relative;
    z-index: 1;
  }

  .coming-badge {
    background: hsla(230, 20%, 30%, 0.5);
    color: hsl(230, 15%, 55%);
    border-color: hsla(230, 20%, 40%, 0.3);
  }

  .coming-card__name {
    font-family: 'Outfit', sans-serif;
    font-weight: 700;
    font-size: 1.2rem;
    color: hsl(230, 15%, 55%);
    margin: 0;
    position: relative;
    z-index: 1;
  }

  .coming-card__hint {
    font-family: 'Inter', sans-serif;
    font-size: 0.8rem;
    color: hsl(230, 15%, 45%);
    line-height: 1.5;
    margin: 0;
    max-width: 28ch;
    position: relative;
    z-index: 1;
  }

  .coming-card__link {
    font-family: 'Inter', sans-serif;
    font-size: 0.8rem;
    font-weight: 600;
    color: hsl(270, 80%, 70%);
    text-decoration: none;
    margin-top: auto;
    position: relative;
    z-index: 1;
    transition: color 0.2s ease;
  }

  .coming-card__link:hover {
    color: hsl(185, 85%, 55%);
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .companies-grid {
      grid-template-columns: 1fr;
    }

    .coming-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
