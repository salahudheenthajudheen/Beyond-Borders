---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCompanies, getCompanyDetail } from '../utils/content-loader';

const companies = getCompanies();
const base = import.meta.env.BASE_URL;

const companyDetails = companies.map(c => ({ company: c, detail: getCompanyDetail(c.slug) }));
const totalUsecases = companies.reduce((sum, c) => sum + c.usecaseCount, 0);
---

<BaseLayout title="Home" description="Beyond Borders — Open innovation intelligence by The Purple Movement.">

  <section class="hero-section">
    <div class="hero-orb" aria-hidden="true"></div>
    <div class="container">
      <div class="hero-content">
        <div class="hero-badge">Open Innovation Intelligence</div>
        <h1 class="hero-title">Beyond Borders</h1>
        <p class="hero-subtitle">A showcase of onboarded companies and the problem statements they have published — structured for builders, researchers, and collaborators.</p>
        <div class="hero-stats">
          <span class="hero-stat">{companies.length} Companies</span>
          <span class="hero-stat-dot">·</span>
          <span class="hero-stat">{totalUsecases} Problem Statements</span>
        </div>
      </div>
    </div>
  </section>

  <div class="section-divider"></div>

  <section class="section">
    <div class="container">
      <div class="flow-card glass-card">
        <div class="flow-card__steps">
          <div class="flow-step">
            <span class="flow-step__index">1</span>
            <h3 class="flow-step__title">Browse companies</h3>
            <p class="flow-step__text">Review each company's profile and context.</p>
          </div>
          <div class="flow-step">
            <span class="flow-step__index">2</span>
            <h3 class="flow-step__title">Pick a problem</h3>
            <p class="flow-step__text">Choose any problem statement below and view the full breakdown.</p>
          </div>
          <div class="flow-step">
            <span class="flow-step__index">3</span>
            <h3 class="flow-step__title">Build & contribute</h3>
            <p class="flow-step__text">Use the details to build a project or submit an improvement.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="section-divider"></div>

  <section class="section">
    <div class="container">
      <div class="company-list">
        {companyDetails.map(({ company, detail }) => (
          <div class="company-block glass-card">
            <div class="company-block__header">
              <div class="company-block__top">
                <h2 class="company-block__name">{company.name}</h2>
                <a href={`${base}/companies/${company.slug}/`} class="company-block__readmore">
                  Full profile →
                </a>
              </div>
              <p class="company-block__summary">{company.summary}</p>
            </div>

            {detail && detail.usecases.length > 0 && (
              <div class="company-block__problems">
                <div class="company-block__label-row">
                  <span class="company-block__label-icon">💡</span>
                  <h3 class="company-block__label">Problem Statements</h3>
                </div>
                <div class="problem-list">
                  {detail.usecases.map(uc => (
                    uc.problems.map(ps => (
                      <a href={`${base}/companies/${company.slug}/${uc.vertical}/${ps.slug}/`} class="problem-link">
                        <span class="problem-link__title">{ps.title}</span>
                        <span class="problem-link__meta">
                          <span class="problem-link__vertical">{uc.vertical.replace(/-/g, ' ')}</span>
                          {ps.scores.overall > 0 && (
                            <span class="problem-link__score">{ps.scores.overall.toFixed(1)}</span>
                          )}
                        </span>
                      </a>
                    ))
                  ))}
                </div>
              </div>
            )}
          </div>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .hero-section {
    position: relative;
    padding: 4rem 0 2.5rem;
    overflow: hidden;
  }

  .hero-orb {
    position: absolute;
    top: -30%;
    right: -10%;
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, hsla(270, 80%, 50%, 0.12), transparent 70%);
    border-radius: 50%;
    pointer-events: none;
  }

  .hero-content {
    position: relative;
    z-index: 1;
  }

  .hero-badge {
    display: inline-block;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: hsl(270, 80%, 70%);
    background: hsla(270, 80%, 65%, 0.1);
    border: 1px solid hsla(270, 80%, 65%, 0.2);
    padding: 0.3rem 0.8rem;
    border-radius: 20px;
    margin-bottom: 1rem;
  }

  .hero-title {
    font-family: var(--font-heading);
    font-size: clamp(2.2rem, 5vw, 3.5rem);
    font-weight: 800;
    margin: 0 0 0.75rem;
    background: linear-gradient(135deg, var(--text-primary), var(--accent-purple));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    line-height: 1.1;
  }

  .hero-subtitle {
    font-family: 'Inter', sans-serif;
    font-size: clamp(0.95rem, 1.5vw, 1.1rem);
    color: hsl(230, 15%, 60%);
    margin: 0 0 1.25rem;
    max-width: 55ch;
    line-height: 1.6;
  }

  .hero-stats {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.8rem;
    color: hsl(230, 15%, 50%);
  }

  .hero-stat-dot {
    color: hsla(270, 80%, 65%, 0.4);
  }

  .section-divider {
    height: 1px;
    background: linear-gradient(90deg, transparent, hsla(270, 80%, 65%, 0.2), hsla(185, 85%, 55%, 0.15), transparent);
    max-width: 800px;
    margin: 0 auto;
  }

  .flow-card {
    padding: 1.5rem 1.75rem;
    background: hsla(230, 20%, 18%, 0.6);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid hsla(230, 20%, 28%, 0.4);
    border-radius: 16px;
  }

  .flow-card__steps {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .flow-step {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .flow-step__index {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.65rem;
    font-weight: 600;
    color: hsl(270, 80%, 65%);
    letter-spacing: 0.06em;
  }

  .flow-step__title {
    font-family: var(--font-heading);
    font-size: 1rem;
    font-weight: 600;
    margin: 0;
    color: var(--text-primary);
  }

  .flow-step__text {
    font-family: 'Inter', sans-serif;
    font-size: 0.8rem;
    color: hsl(230, 15%, 55%);
    line-height: 1.5;
    margin: 0;
  }

  /* ── Company List ── */
  .company-list {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .company-block {
    padding: 1.75rem 2rem;
    background: hsla(230, 20%, 18%, 0.6);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid hsla(230, 20%, 28%, 0.4);
    border-radius: 16px;
    transition: border-color 0.25s ease, box-shadow 0.25s ease, transform 0.25s ease;
  }

  .company-block:hover {
    border-color: hsla(270, 80%, 65%, 0.25);
    box-shadow: 0 8px 32px hsla(270, 80%, 40%, 0.08);
    transform: translateY(-1px);
  }

  .company-block__header {
    margin-bottom: 1.5rem;
    padding-bottom: 1.25rem;
    border-bottom: 1px solid hsla(230, 20%, 22%, 0.6);
  }

  .company-block__top {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 0.5rem;
  }

  .company-block__name {
    font-family: var(--font-heading);
    font-size: 1.35rem;
    font-weight: 700;
    margin: 0;
    color: var(--text-primary);
  }

  .company-block__readmore {
    font-family: 'Inter', sans-serif;
    font-size: 0.8rem;
    font-weight: 600;
    color: hsl(270, 80%, 65%);
    text-decoration: none;
    white-space: nowrap;
    transition: color 0.2s ease;
    flex-shrink: 0;
  }

  .company-block__readmore:hover {
    color: hsl(185, 85%, 60%);
  }

  .company-block__summary {
    font-family: 'Inter', sans-serif;
    font-size: 0.875rem;
    color: hsl(230, 15%, 60%);
    line-height: 1.6;
    margin: 0;
    max-width: 70ch;
  }

  /* ── Problem Statements ── */
  .company-block__label-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
  }

  .company-block__label-icon {
    font-size: 0.9rem;
    line-height: 1;
  }

  .company-block__label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: hsl(230, 15%, 50%);
    margin: 0;
  }

  .problem-list {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .problem-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.65rem 0.85rem;
    border-radius: 10px;
    text-decoration: none;
    color: inherit;
    background: transparent;
    transition: background 0.2s ease;
  }

  .problem-link:hover {
    background: hsla(270, 80%, 65%, 0.06);
  }

  .problem-link__title {
    flex: 1;
    font-family: 'Inter', sans-serif;
    font-size: 0.875rem;
    font-weight: 500;
    color: hsl(0, 0%, 90%);
    line-height: 1.4;
    transition: color 0.2s ease;
  }

  .problem-link:hover .problem-link__title {
    color: hsl(270, 80%, 80%);
  }

  .problem-link__meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-shrink: 0;
  }

  .problem-link__vertical {
    font-family: 'Inter', sans-serif;
    font-size: 0.7rem;
    color: hsl(230, 15%, 48%);
    background: hsla(230, 20%, 22%, 0.5);
    padding: 0.2rem 0.55rem;
    border-radius: 5px;
    white-space: nowrap;
    border: 1px solid hsla(230, 20%, 25%, 0.3);
  }

  .problem-link__score {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.7rem;
    font-weight: 600;
    color: hsl(185, 85%, 55%);
    background: hsla(185, 85%, 55%, 0.1);
    padding: 0.2rem 0.45rem;
    border-radius: 5px;
    border: 1px solid hsla(185, 85%, 55%, 0.2);
    min-width: 2rem;
    text-align: center;
  }

  @media (max-width: 768px) {
    .hero-section {
      padding: 2.5rem 0 1.5rem;
    }

    .flow-card {
      padding: 1.25rem 1rem;
    }

    .flow-card__steps {
      grid-template-columns: 1fr;
    }

    .hero-orb {
      width: 300px;
      height: 300px;
      top: -20%;
    }

    .company-block {
      padding: 1.25rem 1rem;
    }

    .company-block__top {
      flex-direction: column;
      gap: 0.25rem;
    }

    .problem-link {
      flex-wrap: wrap;
    }

    .problem-link__title {
      flex: 1 1 100%;
    }

    .problem-link__meta {
      margin-left: auto;
    }
  }
</style>
