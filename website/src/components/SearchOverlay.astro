---
import type { SearchItem } from '../utils/content-loader';

interface Props {
  searchIndex: SearchItem[];
}
const { searchIndex } = Astro.props;
const serialized = JSON.stringify(searchIndex);
const base = import.meta.env.BASE_URL;
---

<div id="search-overlay" class="search-overlay" role="dialog" aria-modal="true" aria-label="Search" data-search-index={serialized}>
  <div class="search-backdrop" id="search-backdrop"></div>
  <div class="search-modal">
    <div class="search-header">
      <svg class="search-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="11" cy="11" r="8" />
        <line x1="21" y1="21" x2="16.65" y2="16.65" />
      </svg>
      <input
        type="text"
        class="search-input"
        id="search-input"
        placeholder="Search companies, verticals, frameworks, problem statements…"
        autocomplete="off"
        spellcheck="false"
      />
      <kbd class="search-hint">ESC</kbd>
    </div>
    <div class="search-results" id="search-results">
      <div class="search-empty" id="search-empty">
        <span class="search-empty__icon">🔍</span>
        <p>Type to start searching across the ecosystem</p>
      </div>
    </div>
  </div>
</div>

<script>
  (() => {
    const el = document.getElementById('search-overlay');
    const searchIndex = el ? JSON.parse(el.dataset.searchIndex || '[]') : [];
    const overlay = document.getElementById('search-overlay');
    const backdrop = document.getElementById('search-backdrop');
    const input = document.getElementById('search-input');
    const results = document.getElementById('search-results');
    const empty = document.getElementById('search-empty');
    const trigger = document.getElementById('search-trigger');

    let selectedIndex = -1;
    let currentResults = [];

    function openSearch() {
      overlay.classList.add('search-overlay--open');
      setTimeout(() => input.focus(), 100);
      document.body.style.overflow = 'hidden';
      selectedIndex = -1;
      if (input.value) filterResults(input.value);
    }

    function closeSearch() {
      overlay.classList.remove('search-overlay--open');
      document.body.style.overflow = '';
      input.value = '';
      results.innerHTML = '';
      results.appendChild(empty);
      selectedIndex = -1;
      currentResults = [];
    }

    function highlightText(text, query) {
      if (!query) return text;
      const re = new RegExp(`(${query.replace(/[.*+?^${}()|[\]\\]/g, '\\$&')})`, 'gi');
      return text.replace(re, '<mark>$1</mark>');
    }

    function getIcon(type) {
      switch (type) {
        case 'Company': return '🏢';
        case 'Vertical': return '🧭';
        case 'Framework': return '📐';
        case 'Problem Statement': return '💡';
        default: return '📄';
      }
    }

    function filterResults(query) {
      if (!query.trim()) {
        results.innerHTML = '';
        results.appendChild(empty);
        selectedIndex = -1;
        currentResults = [];
        return;
      }

      const q = query.toLowerCase().trim();
      const words = q.split(/\s+/).filter(Boolean);

      // Score and filter items
      const scored = searchIndex.map(item => {
        const titleLower = item.title.toLowerCase();
        const descLower = item.description.toLowerCase();
        let score = 0;
        for (const word of words) {
          if (titleLower.includes(word)) score += 10;
          if (descLower.includes(word)) score += 3;
        }
        return { item, score };
      }).filter(x => x.score > 0)
        .sort((a, b) => b.score - a.score);

      currentResults = scored.map(s => s.item);

      if (currentResults.length === 0) {
        results.innerHTML = `
          <div class="search-empty">
            <span class="search-empty__icon">🔍</span>
            <p>No results found for "<strong>${query}</strong>"</p>
          </div>
        `;
        selectedIndex = -1;
        return;
      }

      // Group by type
      const groups = {};
      for (const item of currentResults) {
        if (!groups[item.type]) groups[item.type] = [];
        groups[item.type].push(item);
      }

      const typeOrder = ['Company', 'Vertical', 'Problem Statement', 'Framework'];
      let html = '';
      let idx = 0;

      for (const type of typeOrder) {
        const items = groups[type];
        if (!items) continue;

        html += `<div class="search-group"><div class="search-group__label">${type}</div>`;
        for (const item of items) {
          const icon = getIcon(item.type);
          html += `
            <a href="${item.url}" class="search-result" data-index="${idx}" onclick="event.stopPropagation()">
              <span class="search-result__icon">${icon}</span>
              <div class="search-result__body">
                <span class="search-result__title">${highlightText(item.title, query)}</span>
                <span class="search-result__desc">${highlightText(item.description.slice(0, 120), query)}</span>
              </div>
            </a>
          `;
          idx++;
        }
        html += `</div>`;
      }

      html += `<div class="search-footer">${currentResults.length} result${currentResults.length !== 1 ? 's' : ''}</div>`;
      results.innerHTML = html;
      selectedIndex = -1;
    }

    // Event handlers
    if (trigger) {
      trigger.addEventListener('click', openSearch);
    }

    if (backdrop) {
      backdrop.addEventListener('click', closeSearch);
    }

    document.addEventListener('keydown', (e) => {
      if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
        e.preventDefault();
        if (overlay.classList.contains('search-overlay--open')) {
          closeSearch();
        } else {
          openSearch();
        }
      }
      if (e.key === 'Escape' && overlay.classList.contains('search-overlay--open')) {
        closeSearch();
      }
      if (overlay.classList.contains('search-overlay--open')) {
        if (e.key === 'ArrowDown') {
          e.preventDefault();
          navigateResults(1);
        } else if (e.key === 'ArrowUp') {
          e.preventDefault();
          navigateResults(-1);
        } else if (e.key === 'Enter' && selectedIndex >= 0) {
          e.preventDefault();
          const link = results.querySelector(`[data-index="${selectedIndex}"]`);
          if (link && link.href) {
            window.location.href = link.href;
          }
        }
      }
    });

    function navigateResults(dir) {
      const items = results.querySelectorAll('.search-result');
      if (items.length === 0) return;

      // Remove previous
      items.forEach(el => el.classList.remove('search-result--active'));
      if (selectedIndex >= 0 && items[selectedIndex]) {
        items[selectedIndex].classList.remove('search-result--active');
      }

      selectedIndex = Math.max(0, Math.min(selectedIndex + dir, items.length - 1));

      items[selectedIndex].classList.add('search-result--active');
      items[selectedIndex].scrollIntoView({ block: 'nearest' });
    }

    if (input) {
      input.addEventListener('input', (e) => filterResults(e.target.value));
    }
  })();
</script>

<style>
  /* ── Overlay ── */
  .search-overlay {
    position: fixed;
    inset: 0;
    z-index: 2000;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding: 8vh 1rem 2rem;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.2s ease;
  }

  .search-overlay--open {
    opacity: 1;
    pointer-events: auto;
  }

  .search-backdrop {
    position: absolute;
    inset: 0;
    background: hsla(230, 25%, 5%, 0.85);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  .search-modal {
    position: relative;
    width: 100%;
    max-width: 640px;
    max-height: 80vh;
    background: hsl(230, 20%, 10%);
    border: 1px solid hsla(270, 80%, 65%, 0.2);
    border-radius: 16px;
    box-shadow:
      0 24px 80px hsla(0, 0%, 0%, 0.6),
      0 0 0 1px hsla(270, 80%, 65%, 0.1);
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  /* ── Header ── */
  .search-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem 1.25rem;
    border-bottom: 1px solid hsla(230, 20%, 20%, 0.6);
    flex-shrink: 0;
  }

  .search-icon {
    flex-shrink: 0;
    color: hsl(230, 15%, 50%);
  }

  .search-input {
    flex: 1;
    background: none;
    border: none;
    outline: none;
    color: hsl(0, 0%, 95%);
    font-family: 'Inter', sans-serif;
    font-size: 1rem;
    line-height: 1.5;
  }

  .search-input::placeholder {
    color: hsl(230, 15%, 45%);
  }

  .search-hint {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.65rem;
    padding: 0.15rem 0.4rem;
    border-radius: 4px;
    background: hsla(230, 20%, 20%, 0.5);
    border: 1px solid hsla(230, 20%, 28%, 0.4);
    color: hsl(230, 15%, 45%);
    flex-shrink: 0;
  }

  /* ── Results ── */
  .search-results {
    flex: 1;
    overflow-y: auto;
    padding: 0.5rem 0;
  }

  .search-empty {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 3rem 1.5rem;
    color: hsl(230, 15%, 50%);
    font-family: 'Inter', sans-serif;
    font-size: 0.9rem;
    text-align: center;
  }

  .search-empty__icon {
    font-size: 2rem;
  }

  .search-group {
    padding: 0 0.5rem;
  }

  .search-group__label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.65rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: hsl(230, 15%, 45%);
    padding: 0.5rem 0.75rem 0.35rem;
  }

  .search-result {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 0.6rem 0.75rem;
    border-radius: 8px;
    text-decoration: none;
    color: inherit;
    transition: background 0.15s ease;
  }

  .search-result:hover,
  .search-result--active {
    background: hsla(270, 80%, 65%, 0.1);
  }

  .search-result__icon {
    font-size: 1.2rem;
    flex-shrink: 0;
    margin-top: 0.1rem;
    line-height: 1;
  }

  .search-result__body {
    flex: 1;
    min-width: 0;
  }

  .search-result__title {
    display: block;
    font-family: 'Inter', sans-serif;
    font-size: 0.875rem;
    font-weight: 600;
    color: hsl(0, 0%, 95%);
    line-height: 1.4;
    margin-bottom: 0.1rem;
  }

  .search-result__title mark {
    background: hsla(270, 80%, 65%, 0.25);
    color: hsl(270, 80%, 80%);
    padding: 0 0.1em;
    border-radius: 2px;
  }

  .search-result__desc {
    display: block;
    font-family: 'Inter', sans-serif;
    font-size: 0.75rem;
    color: hsl(230, 15%, 55%);
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .search-result__desc mark {
    background: hsla(270, 80%, 65%, 0.2);
    color: hsl(230, 15%, 75%);
    padding: 0 0.1em;
    border-radius: 2px;
  }

  .search-footer {
    text-align: center;
    font-family: 'Inter', sans-serif;
    font-size: 0.7rem;
    color: hsl(230, 15%, 40%);
    padding: 0.5rem 0.75rem;
    border-top: 1px solid hsla(230, 20%, 18%, 0.5);
  }

  /* ── Responsive ── */
  @media (max-width: 640px) {
    .search-overlay {
      padding: 1rem;
      align-items: flex-start;
    }

    .search-modal {
      max-height: 90vh;
    }
  }
</style>
