---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import UseCaseCard from '../../../components/UseCaseCard.astro';
import ScoreRadial from '../../../components/ScoreRadial.astro';
import { getCompanies, getCompanyDetail } from '../../../utils/content-loader';
import { renderMarkdown } from '../../../utils/markdown';

export function getStaticPaths() {
  const companies = getCompanies();
  return companies.map(c => ({ params: { slug: c.slug }, props: { company: c } }));
}

const { slug } = Astro.params;
const detail = getCompanyDetail(slug!);
const { company } = Astro.props;

// Render markdown sections
const overviewHtml = renderMarkdown(detail?.overview || '');
const technologyHtml = renderMarkdown(detail?.technology || '');
const researchHtml = renderMarkdown(detail?.research || '');

// Vertical emoji map
const verticalEmojis: Record<string, string> = {
  'agriculture-ai': '🌾',
  'healthcare-ai': '🏥',
  'smart-manufacturing-ai': '🏭',
  'maritime-ai': '🚢',
  'tourism-ai': '🏛️',
  'disaster-management-ai': '🌊',
  'robotics-ai': '🤖',
  'smart-campus-ai': '🎓',
  'civic-tech-ai': '🏛️',
  'climate-tech-ai': '🌍',
  'legal-tech-ai': '⚖️',
};

function getVerticalEmoji(v: string): string {
  return verticalEmojis[v] || '🔬';
}

function formatVerticalName(v: string): string {
  return v
    .replace(/-ai$/, '')
    .split('-')
    .map(w => w.charAt(0).toUpperCase() + w.slice(1))
    .join(' ') + ' AI';
}

// Count totals
const totalUsecases = detail?.usecases.reduce((sum, uc) => sum + uc.problems.length, 0) || 0;
const totalProjects = detail?.projects.length || 0;
const totalVerticals = detail?.usecases.length || 0;

// Tab definitions
const tabs = [
  { id: 'overview', label: 'Overview' },
  { id: 'technology', label: 'Technology' },
  { id: 'usecases', label: 'Use Cases' },
  { id: 'projects', label: 'Projects' },
  { id: 'research', label: 'Research' },
];
---

<BaseLayout title={company.name} description={company.summary}>
  <!-- ── Hero Header ── -->
  <section class="company-hero">
    <div class="container">
      <div class="company-hero__breadcrumb">
        <a href={`${import.meta.env.BASE_URL}`}>Home</a>
        <span class="company-hero__sep">/</span>
        <a href={`${import.meta.env.BASE_URL}companies/`}>Companies</a>
        <span class="company-hero__sep">/</span>
        <span>{company.name}</span>
      </div>

      <h1 class="company-hero__title animate-fade-in-up">{company.name}</h1>
      <p class="company-hero__summary animate-fade-in-up delay-1">{company.summary}</p>

      <div class="company-hero__badges animate-fade-in-up delay-2">
        <span class="badge badge--cyan">{totalUsecases} Use Cases</span>
        <span class="badge badge--emerald">{totalProjects} Projects</span>
        <span class="badge">{totalVerticals} Verticals</span>
        {company.verticals.map((v: string) => (
          <span class="badge">{getVerticalEmoji(v)} {formatVerticalName(v)}</span>
        ))}
      </div>
    </div>
  </section>

  <!-- ── Sticky Tab Nav ── -->
  <nav class="tab-nav" aria-label="Page sections">
    <div class="container">
      <div class="tab-nav__inner">
        {tabs.map(tab => (
          <a href={`#${tab.id}`} class="tab-nav__link">{tab.label}</a>
        ))}
      </div>
    </div>
  </nav>

  <!-- ── Overview Section ── -->
  <section id="overview" class="detail-section">
    <div class="container">
      <div class="section-header">
        <h2 class="section-header__title">Overview</h2>
        <div class="section-header__line"></div>
      </div>
      {overviewHtml ? (
        <div class="glass-panel">
          <div class="md-content" set:html={overviewHtml} />
        </div>
      ) : (
        <div class="glass-panel glass-panel--empty">
          <p class="empty-text">Company overview coming soon.</p>
        </div>
      )}
    </div>
  </section>

  <!-- ── Technology Section ── -->
  <section id="technology" class="detail-section">
    <div class="container">
      <div class="section-header">
        <h2 class="section-header__title">Technology</h2>
        <div class="section-header__line"></div>
      </div>
      {technologyHtml ? (
        <div class="glass-panel">
          <div class="md-content" set:html={technologyHtml} />
        </div>
      ) : (
        <div class="glass-panel glass-panel--empty">
          <p class="empty-text">Technology overview coming soon.</p>
        </div>
      )}
    </div>
  </section>

  <!-- ── Use Cases Section ── -->
  <section id="usecases" class="detail-section">
    <div class="container">
      <div class="section-header">
        <h2 class="section-header__title">Use Cases</h2>
        <div class="section-header__line"></div>
      </div>

      {detail?.usecases && detail.usecases.length > 0 ? (
        detail.usecases.map(uc => (
          <div class="vertical-group">
            <h3 class="vertical-group__heading">
              <span class="vertical-group__emoji">{getVerticalEmoji(uc.vertical)}</span>
              {formatVerticalName(uc.vertical)}
              <span class="badge badge--cyan">{uc.problems.length}</span>
            </h3>
            <div class="usecase-grid">
              {uc.problems.map(ps => (
                <UseCaseCard
                  title={ps.title}
                  href={`${import.meta.env.BASE_URL}companies/${slug}/${uc.vertical}/${ps.slug}/`}
                  vertical={formatVerticalName(uc.vertical)}
                  overallScore={ps.scores.overall}
                />
              ))}
            </div>
          </div>
        ))
      ) : (
        <div class="glass-panel glass-panel--empty">
          <div class="cta-card">
            <span class="cta-card__icon">📋</span>
            <h3 class="cta-card__title">No use cases yet</h3>
            <p class="cta-card__text">Be the first to add a use case for this company.</p>
            <a href={`${import.meta.env.BASE_URL}contribute/`} class="cta-card__btn">Contribute →</a>
          </div>
        </div>
      )}
    </div>
  </section>

  <!-- ── Projects Section ── -->
  <section id="projects" class="detail-section">
    <div class="container">
      <div class="section-header">
        <h2 class="section-header__title">Projects</h2>
        <div class="section-header__line"></div>
      </div>

      {detail?.projects && detail.projects.length > 0 ? (
        <div class="projects-grid">
          {detail.projects.map((project, i) => {
            // Strip markdown chars for a clean excerpt, using hex escapes to avoid confusing Astro parser
            const cleanExcerpt = project.content
              .replace(new RegExp('[#*\\x60\\x3E|-]', 'g'), '')
              .replace(/\n+/g, ' ')
              .trim()
              .substring(0, 150) + '...';

            return (
              <div class="glass-panel project-card">
                <h3 class="project-card__title">{project.title}</h3>
                <p class="project-card__excerpt">{cleanExcerpt}</p>
                <button class="project-card__btn" onclick={`document.getElementById('dialog-${i}').showModal()`}>
                  Read Project →
                </button>
                
                <dialog id={`dialog-${i}`} class="project-dialog">
                  <div class="project-dialog__header">
                    <h3 class="project-dialog__title">{project.title}</h3>
                    <button class="project-dialog__close" onclick={`document.getElementById('dialog-${i}').close()`}>✕</button>
                  </div>
                  <div class="project-dialog__content md-content" set:html={renderMarkdown(project.content)} />
                </dialog>
              </div>
            );
          })}
        </div>
      ) : (
        <div class="glass-panel glass-panel--empty">
          <div class="cta-card">
            <span class="cta-card__icon">🚀</span>
            <h3 class="cta-card__title">No projects yet. Be the first to contribute!</h3>
            <p class="cta-card__text">Build something amazing with this company's technology and problem statements.</p>
            <a href={`${import.meta.env.BASE_URL}contribute/`} class="cta-card__btn">Start a Project →</a>
          </div>
        </div>
      )}
    </div>
  </section>

  <!-- ── Research Section ── -->
  <section id="research" class="detail-section">
    <div class="container">
      <div class="section-header">
        <h2 class="section-header__title">Research</h2>
        <div class="section-header__line"></div>
      </div>

      {researchHtml && researchHtml.trim().length > 30 ? (
        <div class="glass-panel">
          <div class="md-content" set:html={researchHtml} />
        </div>
      ) : (
        <div class="glass-panel glass-panel--empty">
          <div class="cta-card">
            <span class="cta-card__icon">📚</span>
            <h3 class="cta-card__title">Research content coming soon</h3>
            <p class="cta-card__text">Help us build the knowledge base for this company.</p>
            <a href={`${import.meta.env.BASE_URL}contribute/`} class="cta-card__btn">Contribute Research →</a>
          </div>
        </div>
      )}
    </div>
  </section>
</BaseLayout>

<style>
  /* ── Hero ── */
  .company-hero {
    background: var(--gradient-hero);
    padding: var(--sp-16) 0 var(--sp-12);
    position: relative;
    overflow: hidden;
  }

  .company-hero::after {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 60% 50% at 50% 0%, hsla(270, 80%, 40%, 0.12), transparent);
    pointer-events: none;
  }

  .company-hero__breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-body);
    font-size: var(--fs-sm);
    color: var(--text-secondary);
    margin-bottom: var(--sp-6);
  }

  .company-hero__breadcrumb a {
    color: var(--text-secondary);
    text-decoration: none;
    transition: color var(--duration-fast) var(--ease-out);
  }

  .company-hero__breadcrumb a:hover {
    color: var(--accent-purple);
  }

  .company-hero__sep {
    color: hsla(230, 15%, 45%, 0.6);
    font-size: 0.8rem;
  }

  .company-hero__title {
    font-family: var(--font-heading);
    font-size: var(--fs-5xl);
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: var(--sp-4);
  }

  .company-hero__summary {
    font-size: var(--fs-lg);
    color: var(--text-secondary);
    max-width: 60ch;
    line-height: var(--lh-body);
  }

  .company-hero__badges {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-3);
    margin-top: var(--sp-6);
  }

  /* ── Sticky Tab Navigation ── */
  .tab-nav {
    position: sticky;
    top: 72px; /* below navbar */
    z-index: var(--z-sticky);
    background: hsla(230, 25%, 7%, 0.85);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-bottom: 1px solid hsla(230, 20%, 25%, 0.4);
  }

  .tab-nav__inner {
    display: flex;
    gap: var(--sp-1);
    overflow-x: auto;
    scrollbar-width: none;
    -ms-overflow-style: none;
    padding: var(--sp-3) 0;
  }

  .tab-nav__inner::-webkit-scrollbar {
    display: none;
  }

  .tab-nav__link {
    flex-shrink: 0;
    font-family: var(--font-body);
    font-size: var(--fs-sm);
    font-weight: 500;
    color: var(--text-secondary);
    text-decoration: none;
    padding: var(--sp-2) var(--sp-5);
    border-radius: var(--radius-full);
    transition: all var(--duration-fast) var(--ease-out);
    white-space: nowrap;
  }

  .tab-nav__link:hover {
    color: var(--text-primary);
    background: hsla(230, 20%, 20%, 0.5);
  }

  /* ── Detail Sections ── */
  .detail-section {
    padding: var(--sp-16) 0;
    scroll-margin-top: 140px;
  }

  .detail-section:nth-child(even) {
    background: hsla(230, 20%, 9%, 0.5);
  }

  .section-header {
    display: flex;
    align-items: center;
    gap: var(--sp-6);
    margin-bottom: var(--sp-8);
  }

  .section-header__title {
    font-family: var(--font-heading);
    font-size: var(--fs-3xl);
    font-weight: 700;
    color: var(--text-primary);
    white-space: nowrap;
  }

  .section-header__line {
    flex: 1;
    height: 1px;
    background: var(--surface-glass-border);
  }

  /* ── Glass Panel ── */
  .glass-panel {
    background: var(--surface-glass);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: var(--border-glass);
    border-radius: var(--radius-lg);
    padding: var(--sp-10);
  }

  .glass-panel--empty {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--sp-16);
  }

  .empty-text {
    color: var(--text-secondary);
    font-style: italic;
  }

  /* ── CTA Card ── */
  .cta-card {
    text-align: center;
    max-width: 420px;
  }

  .cta-card__icon {
    font-size: 2.5rem;
    display: block;
    margin-bottom: var(--sp-4);
  }

  .cta-card__title {
    font-family: var(--font-heading);
    font-size: var(--fs-xl);
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: var(--sp-3);
  }

  .cta-card__text {
    font-size: var(--fs-sm);
    color: var(--text-secondary);
    margin-bottom: var(--sp-6);
    line-height: var(--lh-body);
  }

  .cta-card__btn {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    font-family: var(--font-body);
    font-size: var(--fs-sm);
    font-weight: 600;
    color: var(--text-primary);
    background: var(--gradient-accent);
    padding: var(--sp-3) var(--sp-6);
    border-radius: var(--radius-full);
    text-decoration: none;
    transition: transform var(--duration-fast) var(--ease-out),
                box-shadow var(--duration-fast) var(--ease-out);
  }

  .cta-card__btn:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-glow-purple);
    color: var(--text-primary);
  }

  /* ── Vertical Group ── */
  .vertical-group {
    margin-bottom: var(--sp-12);
  }

  .vertical-group:last-child {
    margin-bottom: 0;
  }

  .vertical-group__heading {
    display: flex;
    align-items: center;
    gap: var(--sp-3);
    font-family: var(--font-heading);
    font-size: var(--fs-xl);
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: var(--sp-6);
    padding-bottom: var(--sp-3);
    border-bottom: 1px solid hsla(230, 20%, 25%, 0.3);
  }

  .vertical-group__emoji {
    font-size: 1.5rem;
  }

  /* ── Use Case Grid ── */
  .usecase-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: var(--sp-6);
  }

  /* ── Projects Grid ── */
  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: var(--sp-6);
  }

  .project-card {
    display: flex;
    flex-direction: column;
    gap: var(--sp-4);
  }

  .project-card__title {
    font-family: var(--font-heading);
    font-size: var(--fs-xl);
    font-weight: 600;
    color: var(--text-primary);
    margin: 0;
  }

  .project-card__excerpt {
    font-size: var(--fs-sm);
    color: var(--text-secondary);
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .project-card__btn {
    align-self: flex-start;
    margin-top: auto;
    font-family: var(--font-body);
    font-size: var(--fs-sm);
    font-weight: 500;
    color: var(--text-primary);
    background: var(--surface-glass-border);
    padding: var(--sp-2) var(--sp-4);
    border-radius: var(--radius-sm);
    transition: background var(--duration-fast) var(--ease-out);
  }

  .project-card__btn:hover {
    background: hsl(0, 0%, 30%);
  }

  /* ── Dialog ── */
  .project-dialog {
    margin: auto;
    max-width: 800px;
    width: 90%;
    max-height: 85vh;
    padding: 0;
    border: 1px solid var(--surface-glass-border);
    border-radius: var(--radius-lg);
    background: var(--bg-primary);
    color: var(--text-primary);
  }

  .project-dialog::backdrop {
    background: rgba(0, 0, 0, 0.7);
    backdrop-filter: blur(4px);
  }

  .project-dialog__header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--sp-6);
    border-bottom: 1px solid var(--surface-glass-border);
    position: sticky;
    top: 0;
    background: var(--bg-primary);
    z-index: 10;
  }

  .project-dialog__title {
    font-family: var(--font-heading);
    font-size: var(--fs-xl);
    font-weight: 600;
    margin: 0;
  }

  .project-dialog__close {
    font-size: 1.2rem;
    color: var(--text-secondary);
    transition: color var(--duration-fast);
  }

  .project-dialog__close:hover {
    color: var(--text-primary);
  }

  .project-dialog__content {
    padding: var(--sp-6);
    overflow-y: auto;
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .company-hero {
      padding: var(--sp-10) 0 var(--sp-8);
    }

    .company-hero__title {
      font-size: var(--fs-3xl);
    }

    .detail-section {
      padding: var(--sp-10) 0;
    }

    .glass-panel {
      padding: var(--sp-6);
    }

    .usecase-grid {
      grid-template-columns: 1fr;
    }

    .tab-nav__link {
      font-size: var(--fs-xs);
      padding: var(--sp-2) var(--sp-3);
    }
  }
</style>
