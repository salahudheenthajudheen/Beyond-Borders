---
interface Props {
  slug: string;
  name: string;
  summary: string;
  usecaseCount: number;
  projectCount: number;
  verticals: string[];
}
const { slug, name, summary, usecaseCount, projectCount, verticals } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<a href={`${base}companies/${slug}/`} class="company-card">
  <div class="company-card__accent"></div>
  <div class="company-card__body">
    <h3 class="company-card__name">{name}</h3>
    <p class="company-card__summary">{summary}</p>

    <div class="company-card__stats">
      <span class="company-card__badge company-card__badge--purple">
        {usecaseCount} use case{usecaseCount !== 1 ? 's' : ''}
      </span>
      <span class="company-card__badge company-card__badge--cyan">
        {projectCount} project{projectCount !== 1 ? 's' : ''}
      </span>
    </div>

    {verticals.length > 0 && (
      <div class="company-card__verticals">
        {verticals.map(v => (
          <span class="company-card__tag">{v}</span>
        ))}
      </div>
    )}
  </div>
</a>

<style>
  .company-card {
    display: flex;
    text-decoration: none;
    color: inherit;
    background: hsla(230, 20%, 20%, 0.6);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid hsla(230, 20%, 30%, 0.4);
    border-radius: 16px;
    overflow: hidden;
    transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
    position: relative;
  }

  .company-card:hover {
    transform: translateY(-4px) scale(1.01);
    box-shadow: 0 12px 40px hsla(270, 80%, 40%, 0.15);
    border-color: hsla(270, 80%, 65%, 0.3);
  }

  .company-card__accent {
    width: 4px;
    flex-shrink: 0;
    background: var(--surface-glass-border);
    border-radius: 8px 0 0 8px;
  }

  .company-card__body {
    padding: 1.5rem;
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .company-card__name {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 1.2rem;
    margin: 0;
    color: var(--text-primary);
    line-height: 1.3;
  }

  .company-card__summary {
    font-family: 'Inter', sans-serif;
    font-size: 0.875rem;
    color: hsl(230, 15%, 65%);
    line-height: 1.6;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .company-card__stats {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .company-card__badge {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.75rem;
    font-weight: 500;
    padding: 0.25rem 0.65rem;
    border-radius: 20px;
  }

  .company-card__badge--purple {
    background: hsla(270, 80%, 65%, 0.15);
    color: hsl(270, 80%, 75%);
    border: 1px solid hsla(270, 80%, 65%, 0.25);
  }

  .company-card__badge--cyan {
    background: hsla(185, 85%, 55%, 0.12);
    color: hsl(185, 85%, 65%);
    border: 1px solid hsla(185, 85%, 55%, 0.2);
  }

  .company-card__verticals {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
    margin-top: auto;
  }

  .company-card__tag {
    font-family: 'Inter', sans-serif;
    font-size: 0.7rem;
    font-weight: 500;
    color: hsl(230, 15%, 55%);
    background: hsla(230, 20%, 25%, 0.5);
    padding: 0.2rem 0.55rem;
    border-radius: 6px;
    border: 1px solid hsla(230, 20%, 30%, 0.3);
  }

  @media (max-width: 480px) {
    .company-card__body {
      padding: 1.25rem;
    }
  }
</style>
