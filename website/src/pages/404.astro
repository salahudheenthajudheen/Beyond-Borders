---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page Not Found">
  <section class="not-found">
    <!-- Decorative blur orbs -->
    <div class="not-found__orb not-found__orb--1"></div>
    <div class="not-found__orb not-found__orb--2"></div>
    <div class="not-found__orb not-found__orb--3"></div>
    <div class="not-found__orb not-found__orb--4"></div>

    <!-- Grid overlay -->
    <div class="not-found__grid"></div>

    <div class="not-found__content">
      <span class="not-found__code">404</span>
      <h1 class="not-found__title">Page Not Found</h1>
      <p class="not-found__subtitle">This page seems to be beyond our borders.</p>
      <a href={`${import.meta.env.BASE_URL}/`} class="not-found__btn">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
          <polyline points="9 22 9 12 15 12 15 22" />
        </svg>
        Return Home
      </a>
    </div>
  </section>
</BaseLayout>

<style>
  .not-found {
    position: relative;
    min-height: calc(100vh - 80px);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background: var(--bg-primary);
  }

  /* ── Floating orbs ─────────────────────────────────────────── */
  .not-found__orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(100px);
    z-index: 1;
    pointer-events: none;
  }

  .not-found__orb--1 {
    width: 500px;
    height: 500px;
    background: hsla(270, 80%, 45%, 0.12);
    top: -120px;
    right: -80px;
    animation: orbFloat1 10s ease-in-out infinite;
  }

  .not-found__orb--2 {
    width: 350px;
    height: 350px;
    background: hsla(185, 85%, 50%, 0.08);
    bottom: -80px;
    left: -60px;
    animation: orbFloat2 12s ease-in-out infinite;
  }

  .not-found__orb--3 {
    width: 200px;
    height: 200px;
    background: hsla(285, 75%, 50%, 0.1);
    top: 40%;
    left: 20%;
    animation: orbFloat3 8s ease-in-out infinite;
  }

  .not-found__orb--4 {
    width: 250px;
    height: 250px;
    background: hsla(155, 75%, 50%, 0.06);
    top: 20%;
    right: 25%;
    animation: orbFloat1 14s ease-in-out infinite reverse;
  }

  @keyframes orbFloat1 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    33% { transform: translate(30px, -40px) scale(1.05); }
    66% { transform: translate(-20px, 20px) scale(0.95); }
  }

  @keyframes orbFloat2 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    50% { transform: translate(40px, -30px) scale(1.08); }
  }

  @keyframes orbFloat3 {
    0%, 100% { transform: translate(0, 0); }
    50% { transform: translate(-25px, -35px); }
  }

  /* ── Dot grid ──────────────────────────────────────────────── */
  .not-found__grid {
    position: absolute;
    inset: 0;
    z-index: 2;
    opacity: 0.15;
    background-image: radial-gradient(circle, hsla(270, 80%, 65%, 0.4) 1px, transparent 1px);
    background-size: 40px 40px;
  }

  /* ── Content ───────────────────────────────────────────────── */
  .not-found__content {
    position: relative;
    z-index: 3;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--sp-4);
    animation: fadeInUp 0.8s var(--ease-out) both;
    padding: var(--sp-6);
  }

  .not-found__code {
    font-family: var(--font-heading);
    font-weight: 800;
    font-size: clamp(8rem, 20vw, 14rem);
    line-height: 1;
    background: linear-gradient(
      135deg,
      var(--accent-purple),
      var(--accent-violet),
      var(--accent-cyan),
      var(--accent-emerald)
    );
    background-size: 300% 300%;
    animation: gradientShift 6s ease infinite;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    user-select: none;
    letter-spacing: -0.04em;
  }

  .not-found__title {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: var(--fs-2xl);
    color: var(--text-primary);
    margin: 0;
  }

  .not-found__subtitle {
    font-family: var(--font-body);
    font-size: var(--fs-lg);
    color: var(--text-secondary);
    margin: 0;
    max-width: 400px;
    line-height: var(--lh-body);
  }

  .not-found__btn {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-3);
    margin-top: var(--sp-6);
    font-family: var(--font-body);
    font-size: var(--fs-base);
    font-weight: 600;
    padding: var(--sp-4) var(--sp-8);
    border-radius: var(--radius-lg);
    color: white;
    background: linear-gradient(135deg, var(--accent-purple), var(--accent-violet));
    text-decoration: none;
    box-shadow: 0 4px 24px hsla(270, 80%, 50%, 0.3);
    transition:
      transform var(--duration-normal) var(--ease-out),
      box-shadow var(--duration-normal) var(--ease-out);
  }

  .not-found__btn:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 36px hsla(270, 80%, 50%, 0.45);
    color: white;
  }

  /* ── Responsive ────────────────────────────────────────────── */
  @media (max-width: 480px) {
    .not-found__code {
      font-size: 7rem;
    }
  }
</style>
