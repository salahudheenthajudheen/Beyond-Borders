---
import BaseLayout from '../../layouts/BaseLayout.astro';
import UseCaseCard from '../../components/UseCaseCard.astro';
import { getVerticals, getCompanies, getCompanyDetail } from '../../utils/content-loader';
import { renderMarkdown } from '../../utils/markdown';

export function getStaticPaths() {
  const verticals = getVerticals();
  return verticals.map(v => ({ params: { slug: v.slug }, props: { vertical: v } }));
}

const { vertical } = Astro.props;
const htmlContent = renderMarkdown(vertical.content);

// Cross-reference: find all use cases in this vertical across all companies
const companies = getCompanies();
const relatedUsecases: {
  title: string;
  href: string;
  vertical: string;
  overallScore: number;
  company: string;
}[] = [];

for (const company of companies) {
  const detail = getCompanyDetail(company.slug);
  if (!detail) continue;
  for (const uc of detail.usecases) {
    if (uc.vertical === vertical.slug || uc.vertical.includes(vertical.slug.replace('-ai', ''))) {
      for (const ps of uc.problems) {
        relatedUsecases.push({
          title: ps.title,
          href: `/companies/${company.slug}/${uc.vertical}/${ps.slug}`,
          vertical: uc.vertical,
          overallScore: ps.scores.overall,
          company: company.name,
        });
      }
    }
  }
}

// Vertical emoji map
const verticalEmojis: Record<string, string> = {
  'agriculture-ai': '🌾',
  'healthcare-ai': '🏥',
  'smart-manufacturing-ai': '🏭',
  'maritime-ai': '🚢',
  'tourism-ai': '🏛️',
  'disaster-management-ai': '🌊',
  'robotics-ai': '🤖',
  'smart-campus-ai': '🎓',
  'civic-tech-ai': '🏛️',
  'climate-tech-ai': '🌍',
  'legal-tech-ai': '⚖️',
};

const emoji = verticalEmojis[vertical.slug] || '🔬';
---

<BaseLayout title={vertical.name} description={`${vertical.name} — ${relatedUsecases.length} use cases across the Beyond Borders ecosystem`}>
  <!-- ── Hero Header ── -->
  <section class="vertical-hero">
    <div class="container">
      <nav class="vertical-breadcrumb" aria-label="Breadcrumb">
        <a href={`${import.meta.env.BASE_URL}`}>Home</a>
        <span class="vertical-breadcrumb__sep">›</span>
        <a href={`${import.meta.env.BASE_URL}verticals/`}>Verticals</a>
        <span class="vertical-breadcrumb__sep">›</span>
        <span>{vertical.name}</span>
      </nav>

      <div class="vertical-hero__content animate-fade-in-up">
        <span class="vertical-hero__emoji">{emoji}</span>
        <h1 class="vertical-hero__title">{vertical.name}</h1>
        <div class="vertical-hero__badges">
          <span class="badge badge--cyan">{relatedUsecases.length} Use Cases</span>
          <span class="badge badge--emerald">{vertical.companies.length} Companies</span>
        </div>
      </div>
    </div>

    <!-- Decorative gradient orb -->
    <div class="vertical-hero__orb" aria-hidden="true"></div>
  </section>

  <!-- ── Content Section ── -->
  {htmlContent && (
    <section class="vertical-content-section">
      <div class="container">
        <div class="section-header">
          <h2 class="section-header__title">About this Vertical</h2>
          <div class="section-header__line"></div>
        </div>
        <div class="glass-panel">
          <div class="md-content" set:html={htmlContent} />
        </div>
      </div>
    </section>
  )}

  <!-- ── Related Use Cases ── -->
  <section class="vertical-usecases-section">
    <div class="container">
      <div class="section-header">
        <h2 class="section-header__title">Use Cases</h2>
        <div class="section-header__line"></div>
      </div>

      {relatedUsecases.length > 0 ? (
        <div class="usecase-grid">
          {relatedUsecases.map(uc => (
            <UseCaseCard
              title={uc.title}
              href={uc.href}
              vertical={uc.company}
              overallScore={uc.overallScore}
            />
          ))}
        </div>
      ) : (
        <div class="glass-panel glass-panel--empty">
          <div class="cta-card">
            <span class="cta-card__icon">📋</span>
            <h3 class="cta-card__title">No use cases yet</h3>
            <p class="cta-card__text">Be the first to contribute a use case for {vertical.name}.</p>
            <a href={`${import.meta.env.BASE_URL}contribute/`} class="cta-card__btn">Add a Use Case →</a>
          </div>
        </div>
      )}
    </div>
  </section>

  <!-- ── CTA Section ── -->
  <section class="vertical-cta-section">
    <div class="container">
      <div class="cta-banner glass-panel gradient-border">
        <div class="cta-banner__content">
          <span class="cta-banner__emoji">{emoji}</span>
          <div>
            <h3 class="cta-banner__title">Add a use case to {vertical.name}</h3>
            <p class="cta-banner__text">Have an AI problem statement or project idea? Contribute to the Beyond Borders ecosystem.</p>
          </div>
        </div>
        <a href={`${import.meta.env.BASE_URL}contribute/`} class="cta-banner__btn">Contribute →</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ── Hero ── */
  .vertical-hero {
    background: var(--gradient-hero);
    padding: var(--sp-16) 0 var(--sp-12);
    position: relative;
    overflow: hidden;
  }

  .vertical-hero__orb {
    position: absolute;
    top: -30%;
    right: -10%;
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, hsla(270, 80%, 50%, 0.08), transparent 70%);
    border-radius: 50%;
    pointer-events: none;
    animation: float 8s ease-in-out infinite;
  }

  .vertical-hero__content {
    position: relative;
    z-index: 1;
  }

  .vertical-hero__emoji {
    font-size: 3.5rem;
    display: block;
    margin-bottom: var(--sp-4);
    filter: drop-shadow(0 0 20px hsla(270, 80%, 65%, 0.3));
  }

  .vertical-hero__title {
    font-family: var(--font-heading);
    font-size: var(--fs-5xl);
    font-weight: 800;
    letter-spacing: -0.03em;
    background: linear-gradient(135deg, var(--text-primary), var(--accent-purple));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: var(--sp-4);
  }

  .vertical-hero__badges {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-3);
  }

  /* ── Breadcrumb ── */
  .vertical-breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-body);
    font-size: var(--fs-sm);
    color: var(--text-secondary);
    margin-bottom: var(--sp-8);
  }

  .vertical-breadcrumb a {
    color: var(--text-secondary);
    text-decoration: none;
    transition: color var(--duration-fast) var(--ease-out);
  }

  .vertical-breadcrumb a:hover {
    color: var(--accent-purple);
  }

  .vertical-breadcrumb__sep {
    color: hsla(230, 15%, 45%, 0.6);
    font-size: 0.75rem;
  }

  /* ── Content Section ── */
  .vertical-content-section {
    padding: var(--sp-16) 0;
  }

  /* ── Section Header ── */
  .section-header {
    display: flex;
    align-items: center;
    gap: var(--sp-6);
    margin-bottom: var(--sp-8);
  }

  .section-header__title {
    font-family: var(--font-heading);
    font-size: var(--fs-3xl);
    font-weight: 700;
    white-space: nowrap;
    background: linear-gradient(135deg, var(--text-primary), var(--accent-purple));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .section-header__line {
    flex: 1;
    height: 1px;
    background: linear-gradient(90deg, hsla(270, 80%, 65%, 0.3), transparent);
  }

  /* ── Glass Panel ── */
  .glass-panel {
    background: var(--surface-glass);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: var(--border-glass);
    border-radius: var(--radius-lg);
    padding: var(--sp-10);
  }

  .glass-panel--empty {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--sp-16);
  }

  /* ── Use Cases Section ── */
  .vertical-usecases-section {
    padding: var(--sp-16) 0;
    background: hsla(230, 20%, 9%, 0.5);
  }

  .usecase-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: var(--sp-6);
  }

  /* ── CTA Card ── */
  .cta-card {
    text-align: center;
    max-width: 420px;
  }

  .cta-card__icon {
    font-size: 2.5rem;
    display: block;
    margin-bottom: var(--sp-4);
  }

  .cta-card__title {
    font-family: var(--font-heading);
    font-size: var(--fs-xl);
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: var(--sp-3);
  }

  .cta-card__text {
    font-size: var(--fs-sm);
    color: var(--text-secondary);
    margin-bottom: var(--sp-6);
    line-height: var(--lh-body);
  }

  .cta-card__btn {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    font-family: var(--font-body);
    font-size: var(--fs-sm);
    font-weight: 600;
    color: var(--text-primary);
    background: var(--gradient-accent);
    padding: var(--sp-3) var(--sp-6);
    border-radius: var(--radius-full);
    text-decoration: none;
    transition: transform var(--duration-fast) var(--ease-out),
                box-shadow var(--duration-fast) var(--ease-out);
  }

  .cta-card__btn:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-glow-purple);
    color: var(--text-primary);
  }

  /* ── CTA Banner ── */
  .vertical-cta-section {
    padding: var(--sp-12) 0 var(--sp-20);
  }

  .cta-banner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--sp-6);
    padding: var(--sp-8) var(--sp-10);
    background: linear-gradient(135deg, hsla(270, 80%, 30%, 0.2), hsla(185, 50%, 25%, 0.12));
  }

  .cta-banner__content {
    display: flex;
    align-items: center;
    gap: var(--sp-6);
  }

  .cta-banner__emoji {
    font-size: 2.5rem;
    flex-shrink: 0;
  }

  .cta-banner__title {
    font-family: var(--font-heading);
    font-size: var(--fs-xl);
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: var(--sp-2);
  }

  .cta-banner__text {
    font-size: var(--fs-sm);
    color: var(--text-secondary);
    line-height: var(--lh-body);
    max-width: 50ch;
  }

  .cta-banner__btn {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    font-family: var(--font-body);
    font-size: var(--fs-sm);
    font-weight: 600;
    color: var(--text-primary);
    background: var(--gradient-accent);
    padding: var(--sp-3) var(--sp-8);
    border-radius: var(--radius-full);
    text-decoration: none;
    transition: transform var(--duration-fast) var(--ease-out),
                box-shadow var(--duration-fast) var(--ease-out);
    white-space: nowrap;
  }

  .cta-banner__btn:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-glow-purple);
    color: var(--text-primary);
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .vertical-hero {
      padding: var(--sp-10) 0 var(--sp-8);
    }

    .vertical-hero__emoji {
      font-size: 2.5rem;
    }

    .vertical-hero__title {
      font-size: var(--fs-3xl);
    }

    .vertical-content-section,
    .vertical-usecases-section {
      padding: var(--sp-10) 0;
    }

    .glass-panel {
      padding: var(--sp-6);
    }

    .usecase-grid {
      grid-template-columns: 1fr;
    }

    .cta-banner {
      flex-direction: column;
      text-align: center;
      padding: var(--sp-8) var(--sp-6);
    }

    .cta-banner__content {
      flex-direction: column;
    }
  }
</style>
