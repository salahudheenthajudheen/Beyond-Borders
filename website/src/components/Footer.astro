---
const base = import.meta.env.BASE_URL;
---

---

<footer class="footer">
  <div class="footer__gradient-border"></div>
  <div class="footer__inner">
    <div class="footer__grid">
      <!-- Navigation Column -->
      <div class="footer__col">
        <h4 class="footer__heading">Navigation</h4>
        <ul class="footer__nav">
          <li><a href={`${base}/`} class="footer__link">Home</a></li>
          <li><a href={`${base}/companies/`} class="footer__link">Companies</a></li>
          <li><a href={`${base}/verticals/`} class="footer__link">Verticals</a></li>
          <li><a href={`${base}/frameworks/`} class="footer__link">Frameworks</a></li>
          <li><a href={`${base}/resources/`} class="footer__link">Resources</a></li>
          <li><a href={`${base}/contribute/`} class="footer__link">Contribute</a></li>
        </ul>
      </div>

      <!-- About Column -->
      <div class="footer__col">
        <h4 class="footer__heading">About</h4>
        <p class="footer__text">
          Beyond Borders is an open-source innovation intelligence platform curated by
          <strong>The Purple Movement</strong>. We catalog how leading companies leverage emerging
          technology, open-source tools, and forward-thinking strategies to drive impact.
        </p>
      </div>

      <!-- Connect Column -->
      <div class="footer__col">
        <h4 class="footer__heading">Connect</h4>
        <ul class="footer__nav">
          <li>
            <a href="https://github.com/thepurplemovement/Beyond-Borders" class="footer__link" target="_blank" rel="noopener noreferrer">
              <span class="footer__link-icon">⭐</span> GitHub Repository
            </a>
          </li>
          <li>
            <a href="https://thepurplemovement.com" class="footer__link" target="_blank" rel="noopener noreferrer">
              <span class="footer__link-icon">🌐</span> The Purple Movement
            </a>
          </li>
          <li>
            <a href={`${base}/contribute/`} class="footer__link">
              <span class="footer__link-icon">🤝</span> Become a Contributor
            </a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="footer__bottom">
      <p class="footer__copy">&copy; 2026 The Purple Movement. Released under MIT License.</p>
      <p class="footer__built">Built with <a href="https://astro.build" target="_blank" rel="noopener noreferrer" class="footer__astro-link">Astro</a></p>
    </div>
  </div>
</footer>

<style>
  .footer {
    position: relative;
    background: hsla(230, 20%, 9%, 0.8);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    margin-top: auto;
  }

  .footer__gradient-border {
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent,
      hsl(270, 80%, 65%),
      hsl(285, 75%, 55%),
      hsl(185, 85%, 55%),
      transparent
    );
  }

  .footer__inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 3rem 1.5rem 1.5rem;
  }

  .footer__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 3rem;
    margin-bottom: 2.5rem;
  }

  .footer__heading {
    font-family: 'Outfit', sans-serif;
    font-weight: 700;
    font-size: 1rem;
    color: hsl(0, 0%, 95%);
    margin: 0 0 1rem;
    letter-spacing: 0.02em;
  }

  .footer__nav {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .footer__link {
    font-family: 'Inter', sans-serif;
    font-size: 0.875rem;
    color: hsl(230, 15%, 65%);
    text-decoration: none;
    transition: color 0.2s ease;
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .footer__link:hover {
    color: hsl(270, 80%, 75%);
  }

  .footer__link-icon {
    font-size: 0.9rem;
  }

  .footer__text {
    font-family: 'Inter', sans-serif;
    font-size: 0.875rem;
    color: hsl(230, 15%, 65%);
    line-height: 1.7;
    margin: 0;
  }

  .footer__text strong {
    color: hsl(270, 80%, 75%);
    font-weight: 600;
  }

  .footer__bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 1.5rem;
    border-top: 1px solid hsla(230, 20%, 25%, 0.4);
  }

  .footer__copy,
  .footer__built {
    font-family: 'Inter', sans-serif;
    font-size: 0.8rem;
    color: hsl(230, 15%, 45%);
    margin: 0;
  }

  .footer__astro-link {
    color: hsl(270, 80%, 65%);
    text-decoration: none;
    font-weight: 600;
    transition: color 0.2s ease;
  }

  .footer__astro-link:hover {
    color: hsl(185, 85%, 55%);
  }

  @media (max-width: 768px) {
    .footer__grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .footer__bottom {
      flex-direction: column;
      gap: 0.5rem;
      text-align: center;
    }
  }
</style>
